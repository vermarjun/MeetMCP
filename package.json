{
  "name": "meet-agent-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI-powered meeting notes, transcription, and automation",
  "main": "dist/index.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "watch": "node --watch dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "googleapis": "^144.0.0",
    "open": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
